VITE_API_URL=/api

# Produção hardening:
# deixe vazio para não embutir ADMIN_API_KEY no bundle final.
# O operador autentica em runtime e recebe JWT via /auth/login.
# VITE_ALLOW_STATIC_ADMIN_KEY=0
# VITE_ADMIN_API_KEY=

# Se quiser token dedicado para WebSocket (em vez de usar sessão/login):
# VITE_OPS_WS_TOKEN=

