VITE_API_URL=http://127.0.0.1:3210
# Forçar só HTTP (sem WebSocket /ws/ops)
# VITE_OPS_WS=0

# Mapa no painel de roteirização (Maps JavaScript API; chave separada da do servidor ou mesma com referrer HTTP)
# Também dá para colar a chave em Configurações → Geral → Mapa no navegador (só neste aparelho).
# VITE_GOOGLE_MAPS_API_KEY=

# Viés opcional para Place.searchByText em Pedidos (lat/lng da loja)
# VITE_STORE_LAT=-25.36486
# VITE_STORE_LNG=-49.17735

# Opcional: App Check + reCAPTCHA Enterprise para Places API (nova) no JS
# VITE_GOOGLE_MAPS_APP_CHECK=1
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_RECAPTCHA_ENTERPRISE_SITE_KEY=
