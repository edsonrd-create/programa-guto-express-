# Dev: proxy Vite → API (pode omitir e usar só o proxy do vite.config)
VITE_API_URL=http://127.0.0.1:3210

# Producao com nginx (SPA + /api na mesma origem): use relativamente
# VITE_API_URL=/api
# Backend nesse caso: CORS_ORIGINS=https://pdvgutoexpress.com.br,https://www.pdvgutoexpress.com.br

# Hardening recomendado em produção:
# - não embutir ADMIN_API_KEY no build
# - usar login runtime (botão Entrar) e JWT curto vindo de /auth/login
#
# Fallback legado (não recomendado): chave estática no build
# VITE_ALLOW_STATIC_ADMIN_KEY=1
# VITE_ADMIN_API_KEY=

# Forçar só HTTP (sem WebSocket /ws/ops)
# VITE_OPS_WS=0

# Mapa no painel de roteirização (Maps JavaScript API; chave separada da do servidor ou mesma com referrer HTTP)
# Também dá para colar a chave em Configurações → Geral → Mapa no navegador (só neste aparelho).
# VITE_GOOGLE_MAPS_API_KEY=

# Viés opcional para Place.searchByText em Pedidos (lat/lng da loja)
# VITE_STORE_LAT=-25.36486
# VITE_STORE_LNG=-49.17735

# Opcional: App Check + reCAPTCHA Enterprise para Places API (nova) no JS
# VITE_GOOGLE_MAPS_APP_CHECK=1
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_RECAPTCHA_ENTERPRISE_SITE_KEY=
