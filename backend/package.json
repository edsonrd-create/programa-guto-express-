{
  "name": "guto-express-backend",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "npm run test:smoke",
    "dev": "node src/server.js",
    "start": "node src/server.js",
    "seed:integrations": "node scripts/seed-integrations.mjs",
    "test:routing": "node scripts/test-routing.mjs",
    "test:smoke": "node --check src/server.js",
    "test:ci": "npm run test:smoke && node scripts/ci-check-modules.mjs",
    "test:unit": "node --test test/cors-config.test.js",
    "test:integration": "node --test test/server-health.integration.test.mjs",
    "test:node": "node --test test/cors-config.test.js test/server-health.integration.test.mjs test/nuget-version.test.js",
    "test:http-smoke": "node scripts/smoke-http.mjs",
    "smoke:deploy": "node scripts/deploy-smoke.mjs"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "prom-client": "^15.1.3",
    "ws": "^8.18.1",
    "zod": "^4.3.6"
  }
}
