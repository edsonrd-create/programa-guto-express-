PORT=3210
# WebSocket operacional (mesma porta HTTP)
# OPS_WS_DISABLED=1
# OPS_WS_BROADCAST_MS=4000

# Webhooks em fila SQLite (worker em background)
# WEBHOOK_ASYNC=1
# WEBHOOK_WORKER_POLL_MS=1000
# WEBHOOK_JOB_MAX_ATTEMPTS=5
# Geocoding automatico apos criar pedido (endereco sem lat/lng no payload)
# WEBHOOK_GEOCODE_DELIVERY=0

# Google Maps / Routes API v2 (servidor: computeRoutes + Geocoding)
# Ative "Routes API" e "Geocoding API" no projeto Google Cloud e restrinja a chave por IP/referrer.
# GOOGLE_MAPS_API_KEY=
# Rotas com trafego (custo maior): defina 1 para TRAFFIC_AWARE_OPTIMAL
# GOOGLE_ROUTES_TRAFFIC=0
