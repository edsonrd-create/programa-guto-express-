PORT=3210

# Obrigatorio para testes reais / producao: mesma chave no frontend (VITE_ADMIN_API_KEY).
# Exemplo: openssl rand -hex 32
# ADMIN_API_KEY=

# Producao: origens do painel (CORS + /ws/ops). Varias separadas por virgula.
# Painel em producao: https://pdvgutoexpress.com.br/ — inclua tambem https://www. se usar o subdominio www.
# CORS_ORIGINS=https://pdvgutoexpress.com.br,https://www.pdvgutoexpress.com.br
# Dev local (opcional): ,https://127.0.0.1:5173

# Opcional: limite de pedidos por IP (ex.: 3000 por janela). Exclui /health, /metrics, webhooks.
# GLOBAL_RATE_LIMIT_MAX=3000
# GLOBAL_RATE_LIMIT_WINDOW_MS=60000

# WebSocket operacional (mesma porta HTTP)
# OPS_WS_DISABLED=1
# OPS_WS_BROADCAST_MS=4000

# Webhooks em fila SQLite (worker em background)
# WEBHOOK_ASYNC=1
# WEBHOOK_WORKER_POLL_MS=1000
# WEBHOOK_JOB_MAX_ATTEMPTS=5
# Geocoding automatico apos criar pedido (endereco sem lat/lng no payload)
# WEBHOOK_GEOCODE_DELIVERY=0

# Google Maps / Routes API v2 (servidor: computeRoutes + Geocoding)
# Ative "Routes API" e "Geocoding API" no projeto Google Cloud.
# Use uma chave restrita por IP do servidor; o navegador pode usar outra (referrer) em VITE_GOOGLE_MAPS_API_KEY.
# Copie este arquivo para .env e defina ao menos uma das variáveis abaixo:
# GOOGLE_MAPS_API_KEY=AIza...
# alias opcional:
# GOOGLE_MAPS_SERVER_KEY=AIza...
# Se só preencher o frontend/.env com VITE_GOOGLE_MAPS_API_KEY, o backend também carrega (loadEnv.js).
# Rotas com trafego (custo maior): defina 1 para TRAFFIC_AWARE_OPTIMAL
# GOOGLE_ROUTES_TRAFFIC=0
